# Binance or Gemini API Configuration
# 1. Add these to "Settings -> Environment Variables" in the AI Studio UI
BINANCE_API_KEY=
BINANCE_API_SECRET=

# OR FOR GEMINI EXCHANGE
GEMINI_LIVE_API_KEY=
GEMINI_LIVE_API_SECRET=

# SECURITY FLAG: Set to 'true' to unlock real order execution.
# MUST be 'true' for the bot to place orders on your linked account.
ENABLE_REAL_TRADING=true
